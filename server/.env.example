# พอร์ตที่ Backend ใช้งาน
PORT=5000

# MongoDB Connection String
# ถ้าใช้ Local: mongodb://localhost:27017/brevo_email_tracker
# ถ้าใช้ MongoDB Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/brevo_email_tracker
MONGODB_URI=mongodb://localhost:27017/brevo_email_tracker

# Brevo API Key (เอามาจาก Brevo > SMTP & API > API Keys)
BREVO_API_KEY=your-brevo-api-key-here

# อีเมลผู้ส่ง (ต้องเป็นอีเมลที่ Verify แล้วใน Brevo > Senders)
SENDER_EMAIL=you@yourdomain.com
SENDER_NAME=Your App

# Origin ของ Frontend (ใช้สำหรับ CORS) — ตอน dev คือ Vite port 5173
CLIENT_ORIGIN=http://localhost:5173
